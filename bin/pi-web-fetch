#!/usr/bin/env python3
"""Small web-fetch CLI for pi. Fetches a URL and emits readable text/image metadata as JSON."""
import argparse
import hashlib
import html
import json
import mimetypes
import os
from pathlib import Path
import re
import sys
import tempfile
import urllib.request
import urllib.parse

UA = "Mozilla/5.0 pi-web-tools/1.0"


def strip_tags(s: str) -> str:
    return re.sub(r"\s+", " ", re.sub(r"<[^>]+>", " ", html.unescape(s))).strip()


def html_to_text(src: str) -> str:
    src = re.sub(r"<!--[\s\S]*?-->", " ", src)
    src = re.sub(r"<script[\s\S]*?</script>|<style[\s\S]*?</style>|<noscript[\s\S]*?</noscript>|<svg[\s\S]*?</svg>", " ", src, flags=re.I)
    src = re.sub(r"<nav[\s\S]*?</nav>|<footer[\s\S]*?</footer>|<header[\s\S]*?</header>", " ", src, flags=re.I)
    src = re.sub(r"<(h[1-6]|p|li|blockquote|pre|tr|div|section|article|br)\b[^>]*>", "\n", src, flags=re.I)
    src = re.sub(r"</((h[1-6])|p|li|blockquote|pre|tr|div|section|article)>", "\n", src, flags=re.I)
    text = html.unescape(re.sub(r"<[^>]+>", " ", src))
    lines = [re.sub(r"[ \t\f\v]+", " ", line).strip() for line in text.splitlines()]
    return re.sub(r"\n{3,}", "\n\n", "\n".join(line for line in lines if line)).strip()


def safe_image_suffix(url: str, content_type: str) -> str:
    suffix = Path(urllib.parse.urlparse(url).path).suffix.lower()
    if suffix and re.fullmatch(r"\.[a-z0-9]{1,8}", suffix):
        return suffix
    guessed = mimetypes.guess_extension(content_type.split(";", 1)[0].strip().lower())
    return guessed or ".img"


def save_binary(payload: bytes, url: str, content_type: str, output: str | None) -> str:
    if output:
        path = Path(output).expanduser()
        if path.is_dir():
            path = path / ("pi-web-fetch" + safe_image_suffix(url, content_type))
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_bytes(payload)
        return str(path)
    fd, path = tempfile.mkstemp(prefix="pi-web-fetch-", suffix=safe_image_suffix(url, content_type))
    with os.fdopen(fd, "wb") as f:
        f.write(payload)
    return path


def main() -> int:
    p = argparse.ArgumentParser(description="Fetch a URL and emit readable text or saved image metadata as JSON")
    p.add_argument("url")
    p.add_argument("--max-chars", type=int, default=50000)
    p.add_argument("--output", help="Path to write image/binary responses. Defaults to a temp file.")
    args = p.parse_args()

    parsed = urllib.parse.urlparse(args.url)
    if parsed.scheme not in ("http", "https"):
        print(json.dumps({"error": "Only http(s) URLs are supported", "url": args.url}), file=sys.stderr)
        return 2

    max_chars = max(1000, min(200000, args.max_chars))
    try:
        req = urllib.request.Request(args.url, headers={
            "User-Agent": UA,
            "Accept": "text/html,application/xhtml+xml,text/plain,application/json,image/avif,image/webp,image/png,image/jpeg,image/gif,*/*;q=0.5",
        })
        with urllib.request.urlopen(req, timeout=30) as r:
            payload = r.read()
            final_url = r.geturl()
            content_type = r.headers.get("content-type", "")
        media_type = content_type.split(";", 1)[0].strip().lower()
        is_image = media_type.startswith("image/")
        is_text = media_type.startswith("text/") or media_type in ("application/json", "application/xml", "application/xhtml+xml", "application/javascript")

        if is_image or not is_text:
            local_path = save_binary(payload, final_url, content_type, args.output)
            kind = "image" if is_image else "binary"
            text = f"Fetched {kind} from {final_url}\nSaved to: {local_path}\nContent-Type: {content_type or 'unknown'}\nBytes: {len(payload)}"
            print(json.dumps({
                "url": args.url,
                "finalUrl": final_url,
                "kind": kind,
                "contentType": content_type,
                "bytes": len(payload),
                "sha256": hashlib.sha256(payload).hexdigest(),
                "localPath": local_path,
                "text": text,
            }, indent=2))
            return 0

        raw = payload.decode("utf-8", "ignore")
        title_match = re.search(r"<title[^>]*>([\s\S]*?)</title>", raw, re.I)
        title = strip_tags(title_match.group(1)) if title_match else None
        text = html_to_text(raw) if "html" in media_type or "<html" in raw[:1000].lower() else raw.strip()
        out = text[:max_chars]
        print(json.dumps({
            "url": args.url,
            "finalUrl": final_url,
            "kind": "text",
            "title": title,
            "contentType": content_type,
            "charsReturned": len(out),
            "charsExtracted": len(text),
            "truncated": len(text) > max_chars,
            "text": out,
        }, indent=2))
        return 0
    except Exception as e:
        print(json.dumps({"url": args.url, "error": str(e)}), file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
